# cv-manager — identity & contact info
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must never be committed.

# --- Identity ---
CV_FULL_NAME="Your Name"
CV_HEADLINE="Senior Software Engineer"
CV_SUMMARY="One-paragraph professional summary. Concise, outcome-focused."

# --- Contact ---
CV_EMAIL="you@example.com"
CV_PHONE="+00 000 000 0000"
CV_LOCATION="City, Country"

# --- Online presence ---
CV_LINKEDIN="https://www.linkedin.com/in/your-handle"
CV_GITHUB="https://github.com/your-handle"
CV_WEBSITE="https://your-domain.example"
